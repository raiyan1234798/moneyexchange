rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isActiveUser() {
      return isAuthenticated() && userDoc().isActive == true;
    }

    function isSuperAdmin() {
      return isActiveUser() && (
        userDoc().role == 'superAdmin' ||
        request.auth.token.email.lower() == 'abubackerraiyan@gmail.com'
      );
    }

    function canAccessBranch(branchId) {
      return isSuperAdmin() ||
        (isActiveUser() && userDoc().role == 'branchManager' && userDoc().branchId == branchId);
    }

    function isAllowedVideo() {
      return request.resource.contentType.matches('video/.*');
    }

    match /videos/{branchId}/{fileName} {
      allow read: if true;
      allow write: if canAccessBranch(branchId) &&
        isAllowedVideo() &&
        request.resource.size < 500 * 1024 * 1024;
      allow delete: if canAccessBranch(branchId);
    }

    match /branch-logos/{branchId}/{fileName} {
      allow read: if true;
      allow write: if canAccessBranch(branchId) && request.resource.size < 5 * 1024 * 1024;
      allow delete: if canAccessBranch(branchId);
    }
  }
}
