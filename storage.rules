rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAllowedVideo() {
      return request.resource.contentType in ['video/mp4', 'video/webm', 'video/quicktime'];
    }

    match /videos/{branchPath}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isAllowedVideo() && request.resource.size < 500 * 1024 * 1024;
      allow delete: if isAuthenticated();
    }

    match /branch-logos/{branchId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isAuthenticated();
    }
  }
}
